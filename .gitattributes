# Enforce LF line endings everywhere — oxfmt writes LF and is not configurable.
# This prevents CRLF/LF churn on Windows checkouts.
* text=auto eol=lf

# Binary files — never normalize
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.svg   text eol=lf
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.eot   binary
*.pdf   binary
*.zip   binary
*.gz    binary

# Lockfiles — keep LF, mark as generated for diff/PR collapsing
pnpm-lock.yaml -diff linguist-generated=true

# Shell scripts must always be LF
*.sh    text eol=lf

# Windows-only files
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf
