# Editor configuration, see https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = tab
max_line_length = 150
insert_final_newline = true
trim_trailing_whitespace = true

[*.{bat,cmd,ps1}]
end_of_line = crlf

[*.{js,ts}]
spaces_around_operators = inside

[*.{json,yml,yaml,md}]
indent_size = 2
indent_style = space
