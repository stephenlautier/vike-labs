{
  "name": "rift",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nx run-many -t dev --projects=shell,api --parallel",
    "dev:shell": "nx run shell:dev",
    "dev:api": "nx run api:dev",
    "build": "nx run-many -t build",
    "test": "nx run-many -t test --if-present",
    "lint": "nx run-many -t lint",
    "fmt": "nx run-many -t fmt",
    "fmt:check": "nx run-many -t fmt:check",
    "storybook": "nx run storybook:storybook",
    "nx:reset": "nx reset"
  },
  "devDependencies": {
    "@nx/js": "22.7.0",
    "@nx/playwright": "22.7.0",
    "@nx/vite": "22.7.0",
    "@types/node": "catalog:",
    "nx": "22.7.0",
    "oxfmt": "^0.47.0",
    "oxlint": "catalog:",
    "type-fest": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=24.14.0",
    "npm": ">=10.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.9"
}
