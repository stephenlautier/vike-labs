{
  "name": "ui",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "libs/ui/src",
  "tags": ["type:lib", "scope:ui"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm stencil build",
        "cwd": "libs/ui"
      },
      "outputs": ["{workspaceRoot}/dist/{projectRoot}", "{workspaceRoot}/loader", "{workspaceRoot}/www/{projectRoot}"]
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm oxlint src/",
        "cwd": "libs/ui"
      }
    },
    "fmt": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm oxfmt src/",
        "cwd": "libs/ui"
      }
    },
    "fmt:check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm oxfmt --check src/",
        "cwd": "libs/ui"
      }
    }
  }
}
