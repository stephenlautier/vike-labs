{
  "name": "champion",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "libs/champion/src",
  "tags": ["type:lib", "scope:champion"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --project tsconfig.json",
        "cwd": "libs/champion"
      },
      "outputs": ["{workspaceRoot}/libs/{projectRoot}/dist"]
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm oxlint src/",
        "cwd": "libs/champion"
      }
    },
    "test": {
      "executor": "@nx/vite:test",
      "options": {
        "configFile": "libs/champion/vitest.config.ts"
      }
    },
    "fmt": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm oxfmt src/",
        "cwd": "libs/champion"
      }
    },
    "fmt:check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm oxfmt --check src/",
        "cwd": "libs/champion"
      }
    }
  }
}
