{
	"name": "domain",
	"$schema": "../../node_modules/nx/schemas/project-schema.json",
	"projectType": "library",
	"sourceRoot": "libs/domain/src",
	"tags": ["type:lib", "scope:domain"],
	"targets": {
		"build": {
			"executor": "nx:run-commands",
			"options": {
				"command": "tsc --project tsconfig.json",
				"cwd": "libs/domain"
			},
			"outputs": ["{workspaceRoot}/libs/domain/dist"]
		},
		"lint": {
			"executor": "nx:run-commands",
			"options": {
				"command": "pnpm oxlint .",
				"cwd": "libs/domain"
			}
		},
		"test": {
			"executor": "@nx/vite:test",
			"options": {
				"configFile": "libs/domain/vitest.config.ts"
			}
		}
	}
}
