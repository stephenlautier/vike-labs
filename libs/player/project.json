{
  "name": "player",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "libs/player/src",
  "tags": ["type:lib", "scope:player"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -b tsconfig.json",
        "cwd": "libs/player"
      },
      "outputs": ["{workspaceRoot}/libs/{projectRoot}/dist"]
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm oxlint src/",
        "cwd": "libs/player"
      }
    },
    "test": {
      "executor": "@nx/vite:test",
      "options": {
        "configFile": "libs/player/vitest.config.ts"
      }
    }
  }
}
