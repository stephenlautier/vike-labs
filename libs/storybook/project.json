{
  "name": "storybook",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "libs/storybook",
  "targets": {
    "storybook": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm storybook",
        "cwd": "libs/storybook"
      },
      "dependsOn": [{ "projects": ["ui"], "target": "build" }]
    },
    "build-storybook": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm build-storybook",
        "cwd": "libs/storybook"
      },
      "outputs": ["{projectRoot}/storybook-static"],
      "dependsOn": [{ "projects": ["ui"], "target": "build" }]
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm oxlint stories/ .storybook/",
        "cwd": "libs/storybook"
      }
    }
  },
  "tags": ["type:lib", "scope:storybook"]
}
