{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "useTabs": true,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "arrowParens": "avoid",
  "bracketSameLine": true,
  "bracketSpacing": true,
  "printWidth": 120,
  "sortImports": {
    "groups": [
      ["side_effect", "builtin", "external"],
      ["parent", "sibling", "index"]
    ],
    "newlinesBetween": true
  },
  "ignorePatterns": [
    "dist/**",
    "build/**",
    ".vike/**",
    "coverage/**",
    "node_modules/**",
    "*.lock",
    "pnpm-lock.yaml",
    "*.min.js",
    "*.min.css",
    // stencil
    "components.d.ts"
  ],
  "overrides": [
    {
      "files": ["**/*.json", "**/*.jsonc"],
      "options": {
        "useTabs": false,
        "tabWidth": 2
      }
    },
    {
      "files": ["**/*.md", "**/*.mdx"],
      "options": {
        "useTabs": false,
        "tabWidth": 2,
        "printWidth": 80
      }
    },
    {
      "files": ["**/*.yaml", "**/*.yml"],
      "options": {
        "useTabs": false,
        "tabWidth": 2
      }
    }
  ]
}
