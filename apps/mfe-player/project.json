{
	"name": "mfe-player",
	"$schema": "../../node_modules/nx/schemas/project-schema.json",
	"projectType": "library",
	"sourceRoot": "apps/mfe-player/src",
	"tags": ["type:lib", "scope:player"],
	"targets": {
		"build": {
			"executor": "nx:run-commands",
			"options": {
				"command": "pnpm stencil build",
				"cwd": "apps/mfe-player"
			},
			"outputs": [
				"{projectRoot}/dist",
				"{projectRoot}/loader",
				"{projectRoot}/hydrate",
				"{projectRoot}/src/react"
			],
			"dependsOn": ["^build"]
		},
		"lint": {
			"executor": "nx:run-commands",
			"options": {
				"command": "pnpm oxlint src/",
				"cwd": "apps/mfe-player"
			}
		},
		"fmt": {
			"executor": "nx:run-commands",
			"options": {
				"command": "pnpm oxfmt src/",
				"cwd": "apps/mfe-player"
			}
		},
		"fmt:check": {
			"executor": "nx:run-commands",
			"options": {
				"command": "pnpm oxfmt --check src/",
				"cwd": "apps/mfe-player"
			}
		}
	}
}
